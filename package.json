{
  "name": "portfoliovk2",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "node --test --test-concurrency=1",
    "dev": "node node_modules/slicejs-cli/client.js dev --port 3001",
    "build": "node node_modules/slicejs-cli/client.js build",
    "slice:build": "node node_modules/slicejs-cli/client.js build",
    "start": "node node_modules/slicejs-cli/client.js start",
    "slice:create": "node node_modules/slicejs-cli/client.js component create",
    "slice:list": "node node_modules/slicejs-cli/client.js component list",
    "slice:delete": "node node_modules/slicejs-cli/client.js component delete",
    "slice:init": "node node_modules/slicejs-cli/client.js init",
    "slice:version": "node node_modules/slicejs-cli/client.js version",
    "slice:update": "node node_modules/slicejs-cli/client.js update",
    "slice:get": "node node_modules/slicejs-cli/client.js get",
    "slice:browse": "node node_modules/slicejs-cli/client.js browse",
    "slice:sync": "node node_modules/slicejs-cli/client.js sync",
    "test:e2e": "SLICE_BUILD=true playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:dev": "playwright test --project=dev-mode --config tests/e2e/playwright.config.js",
    "test:e2e:prod": "SLICE_BUILD=true playwright test --project=production-mode --config tests/e2e/playwright.config.js"
  },
  "keywords": [
    "portfolio",
    "slicejs",
    "web-components",
    "frontend",
    "developer"
  ],
  "author": "vkneider.dev",
  "license": "ISC",
  "description": "Portfolio de Victor Kneider — Diseño y arquitectura de software profesional. Lo construyo, lo enseño, lo divulgo.",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11"
  },
  "devDependencies": {
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@playwright/test": "^1.59.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "express": "^5.2.1",
    "slicejs-cli": "^3.5.0",
    "slicejs-web-framework": "^3.3.1"
  }
}
